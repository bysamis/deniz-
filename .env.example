# Veritabanı bağlantı adresi (Vercel Postgres, Neon, Supabase vb.)
DATABASE_URL="postgresql://kullanici:sifre@host:5432/veritabani?sslmode=require"

# Oturum (login) çerezlerini imzalamak için rastgele, uzun bir metin.
# Terminalde üretmek için: openssl rand -base64 32
AUTH_SECRET="buraya-uzun-ve-rastgele-bir-metin-yazin"

# İlk yönetici hesabı (yalnızca "npm run db:seed" çalıştırılırken kullanılır)
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="guclu-bir-sifre-secin"
SEED_ADMIN_NAME="Yönetici"
